{
  "info": {
    "name": "WebFestival-API - Notifications",
    "description": "# 🔔 Sistema de Notificaciones\n\nNotificaciones automáticas y manuales.\n\n## Tipos\n- Nuevo concurso\n- Resultados publicados\n- Recordatorio de evaluación\n- Newsletter\n\n## Funcionalidades\n- Notificaciones de usuario\n- Trabajos programados\n- Limpieza automática",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Usuario",
      "item": [
        {
          "name": "Mis Notificaciones",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/notifications?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["notifications"], "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "20"}, {"key": "leidas", "value": "", "disabled": true}]},
            "description": "**Mis notificaciones**\n\nFiltros: leidas (true/false)"
          }
        },
        {
          "name": "Marcar como Leída",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/notifications/{{notificacionId}}/read", "host": ["{{baseUrl}}"], "path": ["notifications", "{{notificacionId}}", "read"]},
            "description": "**Marcar notificación como leída**"
          }
        },
        {
          "name": "Marcar Todas como Leídas",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/notifications/read-all", "host": ["{{baseUrl}}"], "path": ["notifications", "read-all"]},
            "description": "**Marcar todas como leídas**"
          }
        }
      ]
    },
    {
      "name": "Administración (Admin)",
      "item": [
        {
          "name": "Enviar Recordatorio de Fecha Límite",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"concursoId\": {{concursoId}},\n  \"horasAntes\": 24\n}"},
            "url": {"raw": "{{baseUrl}}/notifications/deadline-reminder", "host": ["{{baseUrl}}"], "path": ["notifications", "deadline-reminder"]},
            "description": "**Enviar recordatorio manual (Admin)**"
          }
        },
        {
          "name": "Notificar Evaluación Completada",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"medioId\": {{medioId}},\n  \"juradoId\": \"{{userId}}\"\n}"},
            "url": {"raw": "{{baseUrl}}/notifications/evaluation-complete", "host": ["{{baseUrl}}"], "path": ["notifications", "evaluation-complete"]},
            "description": "**Notificar evaluación completada (Admin)**"
          }
        },
        {
          "name": "Notificar Resultados Publicados",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"concursoId\": {{concursoId}}\n}"},
            "url": {"raw": "{{baseUrl}}/notifications/results-published", "host": ["{{baseUrl}}"], "path": ["notifications", "results-published"]},
            "description": "**Notificar resultados publicados (Admin)**"
          }
        },
        {
          "name": "Notificar Nuevo Concurso",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"concursoId\": {{concursoId}}\n}"},
            "url": {"raw": "{{baseUrl}}/notifications/new-contest", "host": ["{{baseUrl}}"], "path": ["notifications", "new-contest"]},
            "description": "**Notificar nuevo concurso (Admin)**"
          }
        }
      ]
    },
    {
      "name": "Trabajos Programados (Admin)",
      "item": [
        {
          "name": "Iniciar Trabajos Programados",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/notifications/start-scheduled-jobs", "host": ["{{baseUrl}}"], "path": ["notifications", "start-scheduled-jobs"]},
            "description": "**Iniciar trabajos automáticos (Admin)**"
          }
        },
        {
          "name": "Detener Trabajos Programados",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/notifications/stop-scheduled-jobs", "host": ["{{baseUrl}}"], "path": ["notifications", "stop-scheduled-jobs"]},
            "description": "**Detener trabajos automáticos (Admin)**"
          }
        },
        {
          "name": "Limpiar Notificaciones Antiguas",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/notifications/cleanup", "host": ["{{baseUrl}}"], "path": ["notifications", "cleanup"]},
            "description": "**Limpiar notificaciones antiguas (Admin)**\n\nElimina notificaciones leídas de más de 30 días."
          }
        }
      ]
    }
  ]
}
