		{
			"name": "🏆 Gestión de Concursos",
			"item": [
				{
					"name": "Crear Concurso (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('concurso_id', response.data.id);",
									"    console.log('Concurso creado con ID:', response.data.id);",
