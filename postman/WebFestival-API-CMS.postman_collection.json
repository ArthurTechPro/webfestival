{
  "info": {
    "name": "WebFestival API - CMS y Contenido",
    "description": "Colección de endpoints para gestión de contenido, interacciones y búsqueda",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "contenidoId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "commentId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "CMS Principal",
      "item": [
        {
          "name": "1. Obtener Todo el Contenido",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cms/content?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "content"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "2. Obtener Contenido por Tipo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cms/content?tipo=blog_post&estado=publicado",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "content"],
              "query": [
                {
                  "key": "tipo",
                  "value": "blog_post"
                },
                {
                  "key": "estado",
                  "value": "publicado"
                }
              ]
            }
          }
        },
        {
          "name": "3. [CONTENT_ADMIN] Crear Contenido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Guía de Fotografía Urbana\",\n  \"contenido\": \"La fotografía urbana es un arte que captura la esencia de la vida en la ciudad...\",\n  \"tipo\": \"blog_post\",\n  \"estado\": \"borrador\",\n  \"configuracion\": {\n    \"permitir_comentarios\": true,\n    \"destacado\": false,\n    \"template\": \"blog-post-default\"\n  },\n  \"seo\": {\n    \"meta_title\": \"Guía Completa de Fotografía Urbana - WebFestival\",\n    \"meta_description\": \"Aprende las técnicas esenciales para capturar la vida urbana en tus fotografías\",\n    \"keywords\": [\"fotografía\", \"urbana\", \"ciudad\", \"técnicas\"]\n  },\n  \"taxonomia\": {\n    \"categorias\": [\"Fotografía\", \"Tutoriales\"],\n    \"etiquetas\": [\"urbano\", \"técnicas\", \"principiantes\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cms/content",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "content"]
            }
          }
        },
        {
          "name": "4. [CONTENT_ADMIN] Actualizar Contenido",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Guía Avanzada de Fotografía Urbana\",\n  \"estado\": \"publicado\",\n  \"configuracion\": {\n    \"destacado\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cms/content/{{contenidoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "content", "{{contenidoId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Interacciones",
      "item": [
        {
          "name": "1. Dar Like a Contenido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contenidoId\": {{contenidoId}},\n  \"tipoContenido\": \"blog_post\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interactions/like",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "like"]
            }
          }
        },
        {
          "name": "2. Quitar Like",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contenidoId\": {{contenidoId}},\n  \"tipoContenido\": \"blog_post\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interactions/like",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "like"]
            }
          }
        },
        {
          "name": "3. Crear Comentario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contenidoId\": {{contenidoId}},\n  \"tipoContenido\": \"blog_post\",\n  \"contenido\": \"Excelente guía, muy útil para principiantes en fotografía urbana.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interactions/comments",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "comments"]
            }
          }
        },
        {
          "name": "4. Obtener Comentarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/interactions/comments?contenidoId={{contenidoId}}&tipoContenido=blog_post&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "comments"],
              "query": [
                {
                  "key": "contenidoId",
                  "value": "{{contenidoId}}"
                },
                {
                  "key": "tipoContenido",
                  "value": "blog_post"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "5. Reportar Contenido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contenidoId\": {{contenidoId}},\n  \"tipoContenido\": \"blog_post\",\n  \"razon\": \"spam\",\n  \"descripcion\": \"Este contenido parece ser spam promocional\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/interactions/reports",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "reports"]
            }
          }
        },
        {
          "name": "6. [ADMIN] Obtener Estadísticas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/interactions/stats?tipoContenido=blog_post&fechaInicio=2025-01-01&fechaFin=2025-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["interactions", "stats"],
              "query": [
                {
                  "key": "tipoContenido",
                  "value": "blog_post"
                },
                {
                  "key": "fechaInicio",
                  "value": "2025-01-01"
                },
                {
                  "key": "fechaFin",
                  "value": "2025-12-31"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Búsqueda y Analytics",
      "item": [
        {
          "name": "1. Búsqueda Avanzada",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cms/search?q=fotografía&tipo=blog_post&categorias=Fotografía,Tutoriales&orderBy=popularidad",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "fotografía"
                },
                {
                  "key": "tipo",
                  "value": "blog_post"
                },
                {
                  "key": "categorias",
                  "value": "Fotografía,Tutoriales"
                },
                {
                  "key": "orderBy",
                  "value": "popularidad"
                }
              ]
            }
          }
        },
        {
          "name": "2. Autocompletado de Etiquetas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cms/tags/autocomplete?q=foto&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "tags", "autocomplete"],
              "query": [
                {
                  "key": "q",
                  "value": "foto"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "3. Etiquetas Populares",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cms/tags/popular?periodo=30d&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "tags", "popular"],
              "query": [
                {
                  "key": "periodo",
                  "value": "30d"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "4. [CONTENT_ADMIN] Analytics Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cms/analytics/overview?fechaInicio=2025-01-01&fechaFin=2025-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "analytics", "overview"],
              "query": [
                {
                  "key": "fechaInicio",
                  "value": "2025-01-01"
                },
                {
                  "key": "fechaFin",
                  "value": "2025-12-31"
                }
              ]
            }
          }
        },
        {
          "name": "5. [CONTENT_ADMIN] Analytics de Engagement",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cms/analytics/engagement?tipo=blog_post&periodo=30d",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "analytics", "engagement"],
              "query": [
                {
                  "key": "tipo",
                  "value": "blog_post"
                },
                {
                  "key": "periodo",
                  "value": "30d"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Categorías",
      "item": [
        {
          "name": "1. Obtener Categorías",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cms/categories?tipo=blog_post&activo=true",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "categories"],
              "query": [
                {
                  "key": "tipo",
                  "value": "blog_post"
                },
                {
                  "key": "activo",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "2. [CONTENT_ADMIN] Crear Categoría",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Técnicas Avanzadas\",\n  \"descripcion\": \"Contenido sobre técnicas avanzadas de fotografía y video\",\n  \"tipo_taxonomia\": \"categoria\",\n  \"tipo_contenido\": \"blog_post\",\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cms/categories",
              "host": ["{{baseUrl}}"],
              "path": ["cms", "categories"]
            }
          }
        }
      ]
    }
  ]
}