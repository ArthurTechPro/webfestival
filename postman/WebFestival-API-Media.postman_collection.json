{
  "info": {
    "name": "WebFestival API - Media Management",
    "description": "Colección de endpoints para gestión de medios multimedia",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "concursoId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "uploadId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Obtener Configuración de Validación",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/media/validation-config",
          "host": ["{{baseUrl}}"],
          "path": ["media", "validation-config"]
        }
      },
      "response": []
    },
    {
      "name": "2. Generar URL de Subida - Fotografía",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('uploadId', response.data.uploadId);",
              "    console.log('Upload ID guardado:', response.data.uploadId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Atardecer en la Ciudad\",\n  \"tipo_medio\": \"fotografia\",\n  \"categoria_id\": 1,\n  \"formato\": \"image/jpeg\",\n  \"tamaño_archivo\": 2048576\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/media/contests/{{concursoId}}/upload-url",
          "host": ["{{baseUrl}}"],
          "path": ["media", "contests", "{{concursoId}}", "upload-url"]
        }
      },
      "response": []
    },
    {
      "name": "3. Generar URL de Subida - Video",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Documental Urbano\",\n  \"tipo_medio\": \"video\",\n  \"categoria_id\": 2,\n  \"formato\": \"video/mp4\",\n  \"tamaño_archivo\": 52428800\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/media/contests/{{concursoId}}/upload-url",
          "host": ["{{baseUrl}}"],
          "path": ["media", "contests", "{{concursoId}}", "upload-url"]
        }
      },
      "response": []
    },
    {
      "name": "4. Generar URL de Subida - Audio",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Sonidos de la Ciudad\",\n  \"tipo_medio\": \"audio\",\n  \"categoria_id\": 3,\n  \"formato\": \"audio/mp3\",\n  \"tamaño_archivo\": 10485760\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/media/contests/{{concursoId}}/upload-url",
          "host": ["{{baseUrl}}"],
          "path": ["media", "contests", "{{concursoId}}", "upload-url"]
        }
      },
      "response": []
    },
    {
      "name": "5. Generar URL de Subida - Corto de Cine",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Historias Urbanas\",\n  \"tipo_medio\": \"corto_cine\",\n  \"categoria_id\": 4,\n  \"formato\": \"video/mp4\",\n  \"tamaño_archivo\": 104857600\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/media/contests/{{concursoId}}/upload-url",
          "host": ["{{baseUrl}}"],
          "path": ["media", "contests", "{{concursoId}}", "upload-url"]
        }
      },
      "response": []
    },
    {
      "name": "6. Procesar Subida Completada",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"uploadId\": \"{{uploadId}}\",\n  \"immichAssetId\": \"asset-123-456-789\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/media/contests/{{concursoId}}/process-upload",
          "host": ["{{baseUrl}}"],
          "path": ["media", "contests", "{{concursoId}}", "process-upload"]
        }
      },
      "response": []
    },
    {
      "name": "7. Galería de Ganadores",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/media/gallery/winners?tipo_medio=fotografia&page=1&limit=12",
          "host": ["{{baseUrl}}"],
          "path": ["media", "gallery", "winners"],
          "query": [
            {
              "key": "tipo_medio",
              "value": "fotografia"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "12"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "8. Galería de Ganadores - Filtros Avanzados",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/media/gallery/winners?concurso_id=1&año=2025&page=1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["media", "gallery", "winners"],
          "query": [
            {
              "key": "concurso_id",
              "value": "1"
            },
            {
              "key": "año",
              "value": "2025"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "9. Galería Destacada",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/media/gallery/featured?limit=8",
          "host": ["{{baseUrl}}"],
          "path": ["media", "gallery", "featured"],
          "query": [
            {
              "key": "limit",
              "value": "8"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "10. Galería Destacada por Tipo",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/media/gallery/featured?tipo_medio=video&limit=6",
          "host": ["{{baseUrl}}"],
          "path": ["media", "gallery", "featured"],
          "query": [
            {
              "key": "tipo_medio",
              "value": "video"
            },
            {
              "key": "limit",
              "value": "6"
            }
          ]
        }
      },
      "response": []
    }
  ]
}