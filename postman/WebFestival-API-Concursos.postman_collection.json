{
  "info": {
    "name": "WebFestival API - Concursos",
    "description": "Colección de endpoints para gestión de concursos y participación",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "concursoId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Obtener Concursos Activos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/concursos/activos",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "activos"]
        }
      },
      "response": []
    },
    {
      "name": "2. Obtener Concursos Finalizados",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/concursos/finalizados?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "finalizados"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Obtener Concurso por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/concursos/{{concursoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "{{concursoId}}"]
        }
      },
      "response": []
    },
    {
      "name": "4. Inscribirse a Concurso",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"concursoId\": {{concursoId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/concursos/inscripcion",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "inscripcion"]
        }
      },
      "response": []
    },
    {
      "name": "5. Verificar Inscripción",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/concursos/{{concursoId}}/verificar-inscripcion",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "{{concursoId}}", "verificar-inscripcion"]
        }
      },
      "response": []
    },
    {
      "name": "6. Obtener Mis Inscripciones",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/concursos/mis-inscripciones",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "mis-inscripciones"]
        }
      },
      "response": []
    },
    {
      "name": "7. Cancelar Inscripción",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/concursos/inscripcion/{{concursoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "inscripcion", "{{concursoId}}"]
        }
      },
      "response": []
    },
    {
      "name": "8. [ADMIN] Crear Concurso",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Concurso de Fotografía Urbana 2025\",\n  \"descripcion\": \"Captura la esencia de la vida urbana en tus fotografías\",\n  \"reglas\": \"- Solo fotografías originales\\n- Máximo 3 envíos por participante\\n- Formato JPEG o PNG\",\n  \"fecha_inicio\": \"2025-02-01T00:00:00.000Z\",\n  \"fecha_final\": \"2025-03-31T23:59:59.000Z\",\n  \"imagen_url\": \"https://example.com/concurso-urbano.jpg\",\n  \"max_envios\": 3,\n  \"tamano_max_mb\": 10,\n  \"categorias\": [\n    {\n      \"nombre\": \"Arquitectura Urbana\"\n    },\n    {\n      \"nombre\": \"Vida Callejera\"\n    },\n    {\n      \"nombre\": \"Paisaje Urbano\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/concursos",
          "host": ["{{baseUrl}}"],
          "path": ["concursos"]
        }
      },
      "response": []
    },
    {
      "name": "9. [ADMIN] Actualizar Concurso",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Concurso de Fotografía Urbana 2025 - Actualizado\",\n  \"descripcion\": \"Captura la esencia de la vida urbana en tus fotografías - Edición especial\",\n  \"status\": \"ACTIVO\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/concursos/{{concursoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "{{concursoId}}"]
        }
      },
      "response": []
    },
    {
      "name": "10. [ADMIN] Eliminar Concurso",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/concursos/{{concursoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["concursos", "{{concursoId}}"]
        }
      },
      "response": []
    }
  ]
}