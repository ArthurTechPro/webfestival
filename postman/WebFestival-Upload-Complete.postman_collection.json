{
  "info": {
    "name": "WebFestival - Flujo Completo de Subida de Archivos",
    "description": "Colección completa que incluye la subida real de archivos a Immich",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_url}}",
      "type": "string"
    },
    {
      "key": "concurso_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "upload_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "upload_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "immich_api_key",
      "value": "",
      "type": "string"
    },
    {
      "key": "immich_asset_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🚀 Flujo Completo de Subida",
      "item": [
        {
          "name": "1️⃣ Generar URL de Subida - Fotografía",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('upload_url', response.data.uploadUrl);",
                  "    pm.collectionVariables.set('upload_id', response.data.uploadId);",
                  "    pm.collectionVariables.set('immich_api_key', response.data.headers['x-api-key']);",
                  "    ",
                  "    console.log('✅ URL de subida generada');",
                  "    console.log('📝 Upload ID:', response.data.uploadId);",
                  "    console.log('🔑 API Key:', response.data.headers['x-api-key'].substring(0, 10) + '...');",
                  "    console.log('📤 Upload URL:', response.data.uploadUrl);",
                  "    console.log('');",
                  "    console.log('👉 SIGUIENTE PASO: Ejecutar \"2️⃣ Subir Archivo a Immich\"');",
                  "    console.log('   - Selecciona un archivo de imagen en el Body > form-data > assetData');",
                  "} else {",
                  "    console.error('❌ Error generando URL:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Mi Fotografía de Prueba\",\n  \"tipo_medio\": \"fotografia\",\n  \"categoria_id\": 1,\n  \"formato\": \"image/jpeg\",\n  \"tamaño_archivo\": 2048576\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/media/contests/{{concurso_id}}/upload-url",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "media",
                "contests",
                "{{concurso_id}}",
                "upload-url"
              ]
            },
            "description": "Genera una URL segura y temporal para subir archivos a Immich"
          }
        },
        {
          "name": "2️⃣ Subir Archivo a Immich",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('immich_asset_id', response.id);",
                  "    ",
                  "    console.log('✅ Archivo subido exitosamente a Immich');",
                  "    console.log('📝 Asset ID:', response.id);",
                  "    console.log('📁 Ruta original:', response.originalPath);",
                  "    console.log('📄 Nombre archivo:', response.originalFileName);",
                  "    console.log('🎯 Tipo:', response.type);",
                  "    console.log('');",
                  "    console.log('👉 SIGUIENTE PASO: Ejecutar \"3️⃣ Procesar Subida Completada\"');",
                  "} else {",
                  "    console.error('❌ Error subiendo archivo a Immich');",
                  "    console.error('Status:', pm.response.code);",
                  "    console.error('Response:', pm.response.text());",
                  "    console.log('');",
                  "    console.log('💡 TIPS:');",
                  "    console.log('- Asegúrate de seleccionar un archivo en Body > form-data > assetData');",
                  "    console.log('- Verifica que el servidor Immich esté ejecutándose');",
                  "    console.log('- La API key puede haber expirado (15 min), regenera la URL');",
                  "}"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log('🔄 Preparando subida a Immich...');",
                  "console.log('📤 URL:', pm.collectionVariables.get('upload_url'));",
                  "console.log('🔑 API Key:', pm.collectionVariables.get('immich_api_key')?.substring(0, 10) + '...');",
                  "console.log('📝 Upload ID:', pm.collectionVariables.get('upload_id'));",
                  "console.log('');",
                  "console.log('⚠️  IMPORTANTE: Selecciona un archivo de imagen en Body > form-data > assetData');",
                  "console.log('   Formatos soportados: .jpg, .jpeg, .png, .webp');",
                  ""
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{immich_api_key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "assetData",
                  "description": "⚠️ SELECCIONA UN ARCHIVO DE IMAGEN AQUÍ (.jpg, .png, .webp)",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "deviceAssetId",
                  "value": "{{upload_id}}",
                  "type": "text"
                },
                {
                  "key": "deviceId",
                  "value": "webfestival-api",
                  "type": "text"
                },
                {
                  "key": "fileCreatedAt",
                  "value": "{{$isoTimestamp}}",
                  "type": "text"
                },
                {
                  "key": "fileModifiedAt",
                  "value": "{{$isoTimestamp}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{upload_url}}",
              "host": [
                "{{upload_url}}"
              ]
            },
            "description": "Sube el archivo real a Immich usando la URL generada. ⚠️ IMPORTANTE: Debes seleccionar un archivo en el campo 'assetData'."
          }
        },
        {
          "name": "3️⃣ Procesar Subida Completada",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    console.log('🎉 ¡SUBIDA COMPLETADA EXITOSAMENTE!');",
                  "    console.log('');",
                  "    console.log('📊 DETALLES DEL MEDIO:');",
                  "    console.log('🆔 ID en BD:', response.data.id);",
                  "    console.log('📝 Título:', response.data.titulo);",
                  "    console.log('🎯 Tipo:', response.data.tipo_medio);",
                  "    console.log('🏆 Concurso:', response.data.concurso_id);",
                  "    console.log('👤 Usuario:', response.data.usuario_id);",
                  "    console.log('🔗 URL Pública:', response.data.url_publica);",
                  "    console.log('🖼️  Thumbnail:', response.data.url_thumbnail);",
                  "    console.log('📅 Fecha subida:', response.data.fecha_subida);",
                  "    console.log('');",
                  "    console.log('✅ El archivo está ahora disponible en la galería pública');",
                  "    console.log('✅ Los jurados pueden evaluarlo');",
                  "    console.log('✅ Otros usuarios pueden interactuar (likes, comentarios)');",
                  "} else {",
                  "    console.error('❌ Error procesando subida:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uploadId\": \"{{upload_id}}\",\n  \"immichAssetId\": \"{{immich_asset_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/media/contests/{{concurso_id}}/process-upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "media",
                "contests",
                "{{concurso_id}}",
                "process-upload"
              ]
            },
            "description": "Registra el archivo subido en la base de datos y lo hace disponible en la plataforma"
          }
        }
      ],
      "description": "Flujo completo de 3 pasos para subir archivos a WebFestival usando Immich"
    },
