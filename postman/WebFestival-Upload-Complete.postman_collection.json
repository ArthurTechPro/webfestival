    {
      "name": "🔧 Utilidades y Verificación",
      "item": [
        {
          "name": "Verificar Configuración de Validación",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/media/validation-config",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "media",
                "validation-config"
              ]
            },
            "description": "Obtiene los límites y formatos permitidos para cada tipo de medio"
          }
        },
        {
          "name": "Estado de Immich",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{server_url}}/health/immich",
              "host": [
                "{{server_url}}"
              ],
              "path": [
                "health",
                "immich"
              ]
            },
            "description": "Verifica que el servidor Immich esté funcionando correctamente"
          }
        },
        {
          "name": "Ver Logs de Subida",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/media/upload-logs?uploadId={{upload_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "media",
                "upload-logs"
              ],
              "query": [
                {
                  "key": "uploadId",
                  "value": "{{upload_id}}"
                }
              ]
            },
            "description": "Consulta los logs detallados de un proceso de subida específico"
          }
        }
      ],
      "description": "Herramientas para verificar configuración y diagnosticar problemas"
    }
  ]
