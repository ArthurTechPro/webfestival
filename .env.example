# ============================================================
# Variables de entorno — WebFestival Platform
# Copiar a .env y completar con valores reales
# NUNCA subir .env a git
# ============================================================

# ── General ──────────────────────────────────────────────
TZ=America/Bogota
ACME_EMAIL=admin@webfestival.art

# ── Traefik Dashboard ─────────────────────────────────────
# Generar con: htpasswd -nb admin TU_PASSWORD
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xxxx$$xxxx

# ── PostgreSQL (API) ──────────────────────────────────────
POSTGRES_USER=wf_user
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=webfestival

# ── Redis (API) ───────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=CAMBIAR_JWT_SECRET_64_CHARS_MINIMO
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CAMBIAR_JWT_REFRESH_SECRET_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ── Immich ────────────────────────────────────────────────
IMMICH_DB_USER=immich_user
IMMICH_DB_PASSWORD=CAMBIAR_IMMICH_DB_PASSWORD
IMMICH_DB_NAME=immich
IMMICH_API_KEY=OBTENER_DESDE_PANEL_IMMICH

# ── Email ─────────────────────────────────────────────────
# Opciones: smtp | sendgrid | resend
EMAIL_SERVICE=smtp
SMTP_HOST=wf-mailserver
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@webfestival.art
SMTP_PASSWORD=CAMBIAR_SMTP_PASSWORD
SMTP_FROM_EMAIL=noreply@webfestival.art
# Alternativas externas (si no usas servidor propio)
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@webfestival.art
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX

# ── PayPal ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=XXXXXXXXXXXXXXXX
PAYPAL_CLIENT_SECRET=XXXXXXXXXXXXXXXX
PAYPAL_MODE=sandbox

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
