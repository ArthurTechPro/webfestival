{
  "info": {
    "name": "WebFestival-API - Subscriptions",
    "description": "# 💳 Sistema de Suscripciones\n\nPlanes de suscripción y límites de uso.\n\n## Planes\n- Free\n- Basic\n- Premium\n- Enterprise\n\n## Funcionalidades\n- Gestión de planes\n- Procesamiento de pagos (Stripe/PayPal)\n- Límites de uso\n- Webhooks de pago",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Planes",
      "item": [
        {
          "name": "Listar Planes",
          "event": [{
            "listen": "test",
            "script": {"exec": ["if (pm.response.code === 200) {", "    const res = pm.response.json();", "    if (res.data && res.data.length > 0) {", "        pm.environment.set('planId', res.data[0].id);", "    }", "}"]}
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/subscriptions/plans", "host": ["{{baseUrl}}"], "path": ["subscriptions", "plans"]},
            "description": "**Listar planes disponibles**\n\nPlanes públicos activos."
          }
        },
        {
          "name": "Plan por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/subscriptions/plans/{{planId}}", "host": ["{{baseUrl}}"], "path": ["subscriptions", "plans", "{{planId}}"]},
            "description": "**Obtener plan específico**"
          }
        }
      ]
    },
    {
      "name": "Mi Suscripción",
      "item": [
        {
          "name": "Ver Mi Suscripción",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/subscriptions/my-subscription", "host": ["{{baseUrl}}"], "path": ["subscriptions", "my-subscription"]},
            "description": "**Ver suscripción activa**\n\nIncluye plan, uso y límites."
          }
        },
        {
          "name": "Mejorar Suscripción",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"planId\": \"plan_premium\",\n  \"paymentMethodId\": \"pm_123\",\n  \"provider\": \"stripe\"\n}"},
            "url": {"raw": "{{baseUrl}}/subscriptions/upgrade", "host": ["{{baseUrl}}"], "path": ["subscriptions", "upgrade"]},
            "description": "**Mejorar a plan superior**"
          }
        },
        {
          "name": "Cancelar Suscripción",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"reason\": \"No uso suficiente\",\n  \"feedback\": \"Comentarios adicionales\",\n  \"cancel_immediately\": false\n}"},
            "url": {"raw": "{{baseUrl}}/subscriptions/cancel", "host": ["{{baseUrl}}"], "path": ["subscriptions", "cancel"]},
            "description": "**Cancelar suscripción**\n\nCancela al final del período o inmediatamente."
          }
        },
        {
          "name": "Ver Límites",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/subscriptions/limits", "host": ["{{baseUrl}}"], "path": ["subscriptions", "limits"]},
            "description": "**Ver límites de uso**\n\nLímites, uso actual y restante."
          }
        },
        {
          "name": "Verificar Permiso",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/subscriptions/can/create_contest", "host": ["{{baseUrl}}"], "path": ["subscriptions", "can", "create_contest"]},
            "description": "**Verificar si puede realizar acción**\n\nAcciones: create_contest, upload_media, create_private_contest"
          }
        }
      ]
    },
    {
      "name": "Pagos",
      "item": [
        {
          "name": "Procesar Pago",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"planId\": \"plan_premium\",\n  \"paymentMethodId\": \"pm_123\",\n  \"return_url\": \"https://webfestival.com/success\",\n  \"cancel_url\": \"https://webfestival.com/cancel\"\n}"},
            "url": {"raw": "{{baseUrl}}/subscriptions/process-payment?provider=stripe", "host": ["{{baseUrl}}"], "path": ["subscriptions", "process-payment"], "query": [{"key": "provider", "value": "stripe"}]},
            "description": "**Procesar pago de suscripción**\n\nProviders: stripe, paypal"
          }
        },
        {
          "name": "Confirmar PayPal",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"subscriptionId\": \"I-BW452GLLEP1G\",\n  \"token\": \"EC-60U79048BN7719609\"\n}"},
            "url": {"raw": "{{baseUrl}}/subscriptions/confirm-paypal", "host": ["{{baseUrl}}"], "path": ["subscriptions", "confirm-paypal"]},
            "description": "**Confirmar suscripción PayPal**\n\nDespués de aprobación del usuario."
          }
        }
      ]
    },
    {
      "name": "Administración (Admin)",
      "item": [
        {
          "name": "Crear Plan",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"id\": \"plan_enterprise\",\n  \"nombre\": \"Enterprise\",\n  \"descripcion\": \"Plan para empresas\",\n  \"precio_mensual\": 99.99,\n  \"limite_concursos_mes\": 50,\n  \"limite_uploads_mes\": 1000,\n  \"limite_concursos_privados\": 20\n}"},
            "url": {"raw": "{{baseUrl}}/subscriptions/plans", "host": ["{{baseUrl}}"], "path": ["subscriptions", "plans"]},
            "description": "**Crear plan (Admin)**"
          }
        },
        {
          "name": "Actualizar Plan",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"precio_mensual\": 39.99\n}"},
            "url": {"raw": "{{baseUrl}}/subscriptions/plans/{{planId}}", "host": ["{{baseUrl}}"], "path": ["subscriptions", "plans", "{{planId}}"]},
            "description": "**Actualizar plan (Admin)**"
          }
        },
        {
          "name": "Eliminar Plan",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/subscriptions/plans/{{planId}}", "host": ["{{baseUrl}}"], "path": ["subscriptions", "plans", "{{planId}}"]},
            "description": "**Eliminar plan (Admin)**"
          }
        },
        {
          "name": "Métricas",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/subscriptions/metrics", "host": ["{{baseUrl}}"], "path": ["subscriptions", "metrics"]},
            "description": "**Métricas de suscripciones (Admin)**\n\nMRR, ARR, churn rate, etc."
          }
        }
      ]
    }
  ]
}
