{
  "info": {
    "name": "WebFestival-API - Concursos",
    "description": "# 🏆 Gestión de Concursos\n\nSistema completo de concursos multimedia.\n\n## Funcionalidades\n- Consulta de concursos activos y finalizados\n- Inscripción y cancelación\n- CRUD completo (Admin)\n- Verificación de inscripciones\n\n## Roles\n- **Público:** Ver concursos\n- **PARTICIPANTE:** Inscribirse\n- **ADMIN:** Gestión completa",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Consultas Públicas",
      "item": [
        {
          "name": "Concursos Activos",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "    const res = pm.response.json();",
                "    if (res.data && res.data.length > 0) {",
                "        pm.environment.set('concursoId', res.data[0].id);",
                "    }",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/concursos/activos", "host": ["{{baseUrl}}"], "path": ["concursos", "activos"]},
            "description": "**Obtener concursos activos**\n\nRetorna concursos disponibles para inscripción.\n\n**Filtros automáticos:**\n- Estado: Activo\n- Dentro del período de inscripción"
          }
        },
        {
          "name": "Concursos Finalizados",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/concursos/finalizados", "host": ["{{baseUrl}}"], "path": ["concursos", "finalizados"]},
            "description": "**Obtener concursos finalizados**\n\nRetorna concursos con resultados publicados."
          }
        },
        {
          "name": "Detalle de Concurso",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "    const res = pm.response.json();",
                "    if (res.data && res.data.categorias && res.data.categorias.length > 0) {",
                "        pm.environment.set('categoriaId', res.data.categorias[0].id);",
                "    }",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/concursos/{{concursoId}}", "host": ["{{baseUrl}}"], "path": ["concursos", "{{concursoId}}"]},
            "description": "**Obtener detalles del concurso**\n\nIncluye:\n- Información completa\n- Categorías disponibles\n- Reglas y límites"
          }
        }
      ]
    },
    {
      "name": "Inscripciones",
      "item": [
        {
          "name": "Inscribirse",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"concursoId\": {{concursoId}}\n}"},
            "url": {"raw": "{{baseUrl}}/concursos/inscripcion", "host": ["{{baseUrl}}"], "path": ["concursos", "inscripcion"]},
            "description": "**Inscribirse a un concurso**\n\n⚠️ Requisito para subir medios.\n\n**Validaciones:**\n- Concurso activo\n- No inscrito previamente"
          }
        },
        {
          "name": "Cancelar Inscripción",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/concursos/inscripcion/{{concursoId}}", "host": ["{{baseUrl}}"], "path": ["concursos", "inscripcion", "{{concursoId}}"]},
            "description": "**Cancelar inscripción**\n\nElimina la inscripción al concurso."
          }
        },
        {
          "name": "Mis Inscripciones",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/concursos/mis-inscripciones", "host": ["{{baseUrl}}"], "path": ["concursos", "mis-inscripciones"]},
            "description": "**Ver mis inscripciones**\n\nLista de concursos donde estoy inscrito."
          }
        },
        {
          "name": "Verificar Inscripción",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/concursos/{{concursoId}}/verificar-inscripcion", "host": ["{{baseUrl}}"], "path": ["concursos", "{{concursoId}}", "verificar-inscripcion"]},
            "description": "**Verificar estado de inscripción**\n\nConfirma si estás inscrito al concurso."
          }
        }
      ]
    },
    {
      "name": "Administración (Admin)",
      "item": [
        {
          "name": "Listar Todos",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/concursos?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["concursos"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"},
                {"key": "status", "value": "", "disabled": true}
              ]
            },
            "description": "**Listar todos los concursos (Admin)**\n\nCon paginación y filtros."
          }
        },
        {
          "name": "Crear Concurso",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Concurso de Fotografía 2024\",\n  \"descripcion\": \"Concurso anual de fotografía\",\n  \"reglas\": \"Reglas del concurso...\",\n  \"fecha_inicio\": \"2024-03-01T00:00:00Z\",\n  \"fecha_final\": \"2024-03-31T23:59:59Z\",\n  \"max_envios\": 3,\n  \"tamaño_max_mb\": 10\n}"
            },
            "url": {"raw": "{{baseUrl}}/concursos", "host": ["{{baseUrl}}"], "path": ["concursos"]},
            "description": "**Crear nuevo concurso (Admin)**\n\nCrea un concurso con configuración completa."
          }
        },
        {
          "name": "Actualizar Concurso",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Concurso Actualizado\",\n  \"status\": \"Activo\"\n}"
            },
            "url": {"raw": "{{baseUrl}}/concursos/{{concursoId}}", "host": ["{{baseUrl}}"], "path": ["concursos", "{{concursoId}}"]},
            "description": "**Actualizar concurso (Admin)**\n\nModifica datos del concurso."
          }
        },
        {
          "name": "Eliminar Concurso",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{baseUrl}}/concursos/{{concursoId}}", "host": ["{{baseUrl}}"], "path": ["concursos", "{{concursoId}}"]},
            "description": "**Eliminar concurso (Admin)**\n\nElimina un concurso del sistema."
          }
        }
      ]
    }
  ]
}
