// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MODELOS DE USUARIOS Y AUTENTICACIÓN
// ============================================================================

model Usuario {
  id         String   @id @default(cuid())
  nombre     String?
  email      String   @unique
  password   String?
  role       Role     @default(PARTICIPANTE)
  picture_url String?
  bio        String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relaciones
  inscripciones         Inscripcion[]
  medios               Medio[]
  calificaciones       Calificacion[]
  seguimientos_seguidor Seguimiento[] @relation("SeguidorRelation")
  seguimientos_seguido  Seguimiento[] @relation("SeguidoRelation")
  comentarios          Comentario[]
  notificaciones       Notificacion[]
  jurado_especializaciones JuradoEspecializacion[]
  jurado_asignaciones  JuradoAsignacion[]
  user_subscriptions   UserSubscription[]
  contenido_autor      Contenido[] @relation("ContenidoAutor")
  contenido_updated_by Contenido[] @relation("ContenidoUpdatedBy")
  contenido_comentarios ContenidoComentario[]
  contenido_likes      ContenidoLike[]
  contenido_reportes   ContenidoReporte[]
  newsletter_suscriptores NewsletterSuscriptor[]

  @@map("usuarios")
}

enum Role {
  PARTICIPANTE
  JURADO
  ADMIN
  CONTENT_ADMIN
}

// ============================================================================
// ESPECIALIZACIONES DE JURADOS
// ============================================================================

model JuradoEspecializacion {
  id                Int      @id @default(autoincrement())
  usuario_id        String
  especializacion   TipoMedio
  experiencia_anios Int      @default(0)
  certificaciones   String[]
  portfolio_url     String?

  // Relaciones
  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("jurado_especializaciones")
}

// ============================================================================
// SISTEMA DE SUSCRIPCIONES
// ============================================================================

model SubscriptionPlan {
  id       String  @id
  name     String
  price    Decimal @db.Decimal(10, 2)
  currency String  @default("USD")
  interval String
  features Json
  limits   Json
  active   Boolean @default(true)
  created_at DateTime @default(now())

  // Relaciones
  user_subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id                     String   @id @default(cuid())
  user_id                String
  plan_id                String
  status                 String
  current_period_start   DateTime
  current_period_end     DateTime
  cancel_at_period_end   Boolean  @default(false)
  stripe_subscription_id String?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  // Relaciones
  user Usuario @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [plan_id], references: [id])
  usage SubscriptionUsage[]

  @@map("user_subscriptions")
}

model SubscriptionUsage {
  id                    Int      @id @default(autoincrement())
  subscription_id       String
  period_start          DateTime
  period_end            DateTime
  concursos_used        Int      @default(0)
  uploads_used          Int      @default(0)
  private_contests_used Int      @default(0)
  team_members_used     Int      @default(0)

  // Relaciones
  subscription UserSubscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@map("subscription_usage")
}

// ============================================================================
// CONCURSOS Y CATEGORÍAS
// ============================================================================

model Concurso {
  id             Int      @id @default(autoincrement())
  titulo         String
  descripcion    String
  reglas         String?
  fecha_inicio   DateTime
  fecha_final    DateTime
  status         StatusConcurso @default(PROXIMAMENTE)
  imagen_url     String?
  max_envios     Int      @default(3)
  tamano_max_mb  Int      @default(10)
  created_at     DateTime @default(now())

  // Relaciones
  categorias    Categoria[]
  inscripciones Inscripcion[]
  medios        Medio[]

  @@map("concursos")
}

enum StatusConcurso {
  PROXIMAMENTE
  ACTIVO
  CALIFICACION
  FINALIZADO
}

model Categoria {
  id          Int @id @default(autoincrement())
  nombre      String
  concurso_id Int

  // Relaciones
  concurso            Concurso           @relation(fields: [concurso_id], references: [id], onDelete: Cascade)
  medios              Medio[]
  jurado_asignaciones JuradoAsignacion[]

  @@map("categorias")
}

// ============================================================================
// INSCRIPCIONES
// ============================================================================

model Inscripcion {
  id                 Int      @id @default(autoincrement())
  usuario_id         String
  concurso_id        Int
  fecha_inscripcion  DateTime @default(now())

  // Relaciones
  usuario  Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  concurso Concurso @relation(fields: [concurso_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, concurso_id])
  @@map("inscripciones")
}

// ============================================================================
// MEDIOS MULTIMEDIA
// ============================================================================

model Medio {
  id             Int       @id @default(autoincrement())
  titulo         String
  tipo_medio     TipoMedio
  usuario_id     String
  concurso_id    Int
  categoria_id   Int
  medio_url      String
  thumbnail_url  String?
  preview_url    String?
  duracion       Int?      // para videos y audios en segundos
  formato        String
  tamano_archivo BigInt
  metadatos      Json?
  fecha_subida   DateTime  @default(now())

  // Relaciones
  usuario        Usuario        @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  concurso       Concurso       @relation(fields: [concurso_id], references: [id], onDelete: Cascade)
  categoria      Categoria      @relation(fields: [categoria_id], references: [id], onDelete: Cascade)
  calificaciones Calificacion[]
  comentarios    Comentario[]

  @@map("medios")
}

enum TipoMedio {
  fotografia
  video
  audio
  corto_cine
}

// ============================================================================
// ASIGNACIONES DE JURADOS
// ============================================================================

model JuradoAsignacion {
  id           Int @id @default(autoincrement())
  usuario_id   String
  categoria_id Int

  // Relaciones
  usuario   Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  categoria Categoria @relation(fields: [categoria_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, categoria_id])
  @@map("jurado_asignaciones")
}

// ============================================================================
// CRITERIOS DE EVALUACIÓN
// ============================================================================

model Criterio {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique
  descripcion String?
  tipo_medio  TipoMedio?
  peso        Decimal    @default(1.0) @db.Decimal(5, 2)
  activo      Boolean    @default(true)
  orden       Int        @default(0)

  // Relaciones
  calificaciones_detalle CalificacionDetalle[]

  @@map("criterios")
}

// ============================================================================
// CALIFICACIONES
// ============================================================================

model Calificacion {
  id                  Int      @id @default(autoincrement())
  medio_id            Int
  jurado_id           String
  comentarios         String?
  fecha_calificacion  DateTime @default(now())

  // Relaciones
  medio    Medio                 @relation(fields: [medio_id], references: [id], onDelete: Cascade)
  jurado   Usuario               @relation(fields: [jurado_id], references: [id], onDelete: Cascade)
  detalles CalificacionDetalle[]

  @@unique([medio_id, jurado_id])
  @@map("calificaciones")
}

model CalificacionDetalle {
  id              Int @id @default(autoincrement())
  calificacion_id Int
  criterio_id     Int
  puntuacion      Int @db.SmallInt // 1-10

  // Relaciones
  calificacion Calificacion @relation(fields: [calificacion_id], references: [id], onDelete: Cascade)
  criterio     Criterio     @relation(fields: [criterio_id], references: [id], onDelete: Cascade)

  @@unique([calificacion_id, criterio_id])
  @@map("calificaciones_detalle")
}

// ============================================================================
// SISTEMA SOCIAL
// ============================================================================

model Seguimiento {
  id                 Int      @id @default(autoincrement())
  seguidor_id        String
  seguido_id         String
  fecha_seguimiento  DateTime @default(now())

  // Relaciones
  seguidor Usuario @relation("SeguidorRelation", fields: [seguidor_id], references: [id], onDelete: Cascade)
  seguido  Usuario @relation("SeguidoRelation", fields: [seguido_id], references: [id], onDelete: Cascade)

  @@unique([seguidor_id, seguido_id])
  @@map("seguimientos")
}

model Comentario {
  id               Int      @id @default(autoincrement())
  medio_id         Int
  usuario_id       String
  contenido        String
  fecha_comentario DateTime @default(now())
  reportado        Boolean  @default(false)

  // Relaciones
  medio   Medio   @relation(fields: [medio_id], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("comentarios")
}

// ============================================================================
// NOTIFICACIONES
// ============================================================================

model Notificacion {
  id              Int      @id @default(autoincrement())
  usuario_id      String
  tipo            String
  titulo          String
  mensaje         String
  leida           Boolean  @default(false)
  fecha_creacion  DateTime @default(now())

  // Relaciones
  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

// ============================================================================
// SISTEMA CMS UNIFICADO
// ============================================================================

model Contenido {
  id                 Int       @id @default(autoincrement())
  tipo               String
  slug               String    @unique
  titulo             String
  contenido          String?
  resumen            String?
  imagen_destacada   String?
  autor_id           String
  estado             EstadoContenido @default(BORRADOR)
  fecha_publicacion  DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  updated_by         String?

  // Relaciones
  autor                Usuario                @relation("ContenidoAutor", fields: [autor_id], references: [id], onDelete: Cascade)
  updated_by_user      Usuario?               @relation("ContenidoUpdatedBy", fields: [updated_by], references: [id])
  configuracion        ContenidoConfiguracion?
  seo                  ContenidoSEO?
  metricas             ContenidoMetricas?
  taxonomia            ContenidoTaxonomia[]
  comentarios          ContenidoComentario[]
  likes                ContenidoLike[]
  reportes             ContenidoReporte[]

  @@map("contenido")
}

enum EstadoContenido {
  BORRADOR
  PUBLICADO
  ARCHIVADO
  PROGRAMADO
}

model ContenidoConfiguracion {
  contenido_id            Int     @id
  activo                  Boolean @default(true)
  orden                   Int     @default(0)
  permite_comentarios     Boolean @default(true)
  destacado               Boolean @default(false)
  configuracion_adicional Json?

  // Relaciones
  contenido Contenido @relation(fields: [contenido_id], references: [id], onDelete: Cascade)

  @@map("contenido_configuracion")
}

model ContenidoSEO {
  contenido_id     Int      @id
  seo_titulo       String?
  seo_descripcion  String?
  seo_keywords     String[]
  meta_tags        Json?
  structured_data  Json?

  // Relaciones
  contenido Contenido @relation(fields: [contenido_id], references: [id], onDelete: Cascade)

  @@map("contenido_seo")
}

model ContenidoMetricas {
  contenido_id        Int       @id
  vistas              Int       @default(0)
  likes               Int       @default(0)
  comentarios_count   Int       @default(0)
  shares              Int       @default(0)
  ultima_vista        DateTime?
  primera_publicacion DateTime?

  // Relaciones
  contenido Contenido @relation(fields: [contenido_id], references: [id], onDelete: Cascade)

  @@map("contenido_metricas")
}

model ContenidoTaxonomia {
  id               Int    @id @default(autoincrement())
  contenido_id     Int
  categoria        String?
  etiqueta         String?
  tipo_taxonomia   TipoTaxonomia

  // Relaciones
  contenido Contenido @relation(fields: [contenido_id], references: [id], onDelete: Cascade)

  @@map("contenido_taxonomia")
}

enum TipoTaxonomia {
  categoria
  etiqueta
}

// ============================================================================
// INTERACCIONES UNIFICADAS
// ============================================================================

model ContenidoComentario {
  id                Int      @id @default(autoincrement())
  contenido_id      Int
  tipo_contenido    String
  usuario_id        String
  contenido_texto   String
  aprobado          Boolean  @default(false)
  reportado         Boolean  @default(false)
  parent_id         Int?
  fecha_comentario  DateTime @default(now())

  // Relaciones
  contenido Contenido @relation(fields: [contenido_id], references: [id], onDelete: Cascade)
  usuario   Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  parent    ContenidoComentario? @relation("ComentarioParent", fields: [parent_id], references: [id])
  replies   ContenidoComentario[] @relation("ComentarioParent")

  @@map("contenido_comentarios")
}

model ContenidoLike {
  id               Int      @id @default(autoincrement())
  contenido_id     Int
  tipo_contenido   String
  usuario_id       String
  fecha_like       DateTime @default(now())

  // Relaciones
  contenido Contenido @relation(fields: [contenido_id], references: [id], onDelete: Cascade)
  usuario   Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@unique([contenido_id, tipo_contenido, usuario_id])
  @@map("contenido_likes")
}

model ContenidoReporte {
  id               Int      @id @default(autoincrement())
  elemento_id      Int
  tipo_elemento    String
  usuario_id       String
  razon            String
  descripcion      String?
  estado           EstadoReporte @default(PENDIENTE)
  fecha_reporte    DateTime @default(now())
  fecha_resolucion DateTime?
  resuelto_por     String?

  // Relaciones
  usuario   Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  contenido Contenido @relation(fields: [elemento_id], references: [id], onDelete: Cascade)

  @@map("contenido_reportes")
}

enum EstadoReporte {
  PENDIENTE
  REVISANDO
  APROBADO
  RECHAZADO
  RESUELTO
}

// ============================================================================
// NEWSLETTER
// ============================================================================

model NewsletterSuscriptor {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  usuario_id        String?
  activo            Boolean   @default(true)
  confirmado        Boolean   @default(false)
  token_confirmacion String?  @unique
  fecha_suscripcion DateTime  @default(now())
  fecha_confirmacion DateTime?
  fecha_cancelacion DateTime?

  // Relaciones
  usuario Usuario? @relation(fields: [usuario_id], references: [id], onDelete: SetNull)

  @@map("newsletter_suscriptores")
}