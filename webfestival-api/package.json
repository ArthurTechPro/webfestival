{
  "name": "webfestival-api",
  "version": "1.0.0",
  "description": "Backend API for WebFestival multimedia contest platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "verify-criterios": "tsx src/scripts/verify-criterios.ts",
    "test-criterios": "tsx src/scripts/test-criterios-service.ts",
    "init-plans": "tsx src/scripts/init-subscription-plans.ts",
    "verify-auth": "tsx src/scripts/verify-auth-config.ts",
    "verify-immich": "tsx src/scripts/verify-immich-connection.ts",
    "verify-media-gallery": "tsx src/scripts/verify-media-gallery-implementation.ts",
    "verify-calificacion-system": "tsx src/scripts/verify-calificacion-system.ts"
  },
  "keywords": [
    "webfestival",
    "api",
    "multimedia",
    "contests"
  ],
  "author": "WebFestival Team",
  "license": "MIT",
  "dependencies": {
    "@immich/sdk": "^1.138.1",
    "@prisma/client": "^5.8.1",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "stripe": "^18.5.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "prisma": "^5.8.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
